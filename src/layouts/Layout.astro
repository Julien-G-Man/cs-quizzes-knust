---
interface Props {
  title: string;
  description?: string;
  ogUrl?: string;
}
const {
  title,
  description = 'Lamla Quiz Hub helps you practice CS past questions in one mobile-friendly learning space.',
  ogUrl = 'https://lamla-quiz-hub.netlify.app/',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={ogUrl}>
  <meta property="og:image" content="https://lamla-quiz-hub.netlify.app/img/hero.png">
  <meta property="og:type" content="website">
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');
    :root {
      --bg: #f4efe7;
      --panel: #fffaf2;
      --ink: #171717;
      --muted: #4a4036;
      --accent: #1f5d4e;
      --accent-2: #b46b2f;
      --accent-3: #102e44;
      --border: rgba(35, 35, 35, 0.12);
      --shadow: 0 24px 80px rgba(44, 28, 13, 0.12);
      --success: #216e39;
      --error: #b42318;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      font-family: 'IBM Plex Sans', sans-serif;
      background:
        radial-gradient(circle at top left, rgba(31, 93, 78, 0.18), transparent 34%),
        radial-gradient(circle at top right, rgba(180, 107, 47, 0.16), transparent 30%),
        linear-gradient(180deg, #fff8ef 0%, #f4efe7 100%);
    }
    .wrap { max-width: 1120px; margin: 0 auto; padding: 24px 16px 48px; }
    h1, h2 { font-family: 'Fraunces', serif; line-height: 1.05; margin: 0; }
    h1 { font-size: clamp(2rem, 5vw, 3.8rem); }
    .kicker {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 0.78rem;
      color: rgba(248, 243, 234, 0.78);
      margin: 0 0 10px;
    }
    .hero {
      background: linear-gradient(145deg, rgba(35, 35, 35, 0.96), rgba(31, 93, 78, 0.96));
      color: #f8f3ea;
      border-radius: 28px;
      padding: 32px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }
    .hero::after {
      content: '';
      position: absolute;
      inset: auto -120px -120px auto;
      width: 260px; height: 260px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
      filter: blur(2px);
    }
    .hero p { margin: 16px 0 0; max-width: 780px; color: rgba(255, 249, 240, 0.98); line-height: 1.65; }
    .hero-layout { display: grid; grid-template-columns: 1.4fr 0.8fr; gap: 18px; align-items: stretch; }
    .hero-copy { position: relative; z-index: 1; }
    .hero-side {
      position: relative; z-index: 1;
      display: flex; flex-direction: column; justify-content: space-between; gap: 12px;
      padding: 18px; border-radius: 22px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.12);
    }
    .hero-badges { display: flex; flex-wrap: wrap; gap: 10px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 9px 12px; border-radius: 999px;
      background: rgba(255, 255, 255, 0.08); color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.12);
      font-size: 0.82rem; white-space: nowrap;
    }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px; }
    .feature-strip { margin-top: 16px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
    .feature { padding: 14px 16px; border-radius: 18px; background: rgba(255, 255, 255, 0.72); border: 1px solid var(--border); }
    .feature span { display: block; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 6px; }
    .feature strong { display: block; font-size: 0.98rem; line-height: 1.35; }
    .panel { margin-top: 18px; background: rgba(255, 250, 242, 0.92); border: 1px solid var(--border); border-radius: 24px; box-shadow: var(--shadow); backdrop-filter: blur(12px); }
    .menu { padding: 24px; }
    .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
    .card {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.74));
      border: 1px solid var(--border); border-radius: 22px; padding: 20px;
      display: flex; flex-direction: column; gap: 14px; min-height: 240px;
      position: relative; overflow: hidden;
    }
    .card::before {
      content: ''; position: absolute; inset: 0 auto auto 0;
      width: 100%; height: 6px;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
    }
    .tag {
      display: inline-flex; align-items: center; width: fit-content;
      border-radius: 999px; padding: 8px 12px;
      background: rgba(31, 93, 78, 0.08); color: var(--accent);
      font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700;
    }
    .card h2 { font-size: 1.35rem; }
    .card p { margin: 0; color: var(--muted); line-height: 1.65; }
    .actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: auto; }
    .btn, .btn-disabled {
      display: inline-flex; align-items: center; justify-content: center;
      text-decoration: none; border-radius: 14px; padding: 12px 16px;
      font-weight: 700; font-family: inherit;
      border: 1px solid var(--border);
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }
    .btn { background: var(--accent); color: #fff; box-shadow: 0 10px 24px rgba(31, 93, 78, 0.2); }
    .btn-secondary { background: transparent; color: var(--ink); }
    .btn-light { background: rgba(255, 255, 255, 0.08); color: #fff; border: 1px solid rgba(255, 255, 255, 0.18); }
    .btn-disabled { background: rgba(35, 35, 35, 0.05); color: #786d63; cursor: not-allowed; }
    .btn:hover, .btn-secondary:hover { transform: translateY(-1px); }
    .note { margin-top: 18px; padding: 14px 16px; border-radius: 18px; background: rgba(31, 93, 78, 0.08); color: var(--muted); border: 1px solid rgba(31, 93, 78, 0.14); line-height: 1.6; }
    .hidden { display: none !important; }
    @media (max-width: 900px) {
      .hero-layout, .grid, .feature-strip { grid-template-columns: 1fr; }
      .wrap { padding: 14px 10px 32px; }
      .hero { padding: 20px; border-radius: 20px; }
      .panel { border-radius: 18px; }
      .hero-side { padding: 14px; }
      .hero-actions { margin-top: 18px; }
      .card { min-height: auto; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <slot />
  </div>
</body>
</html>
