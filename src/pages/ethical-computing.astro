---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---
<Layout
  title="Ethical Implications of Computing | Lamla Quiz Hub"
  description="Ethical Implications of Computing course page inside Lamla Quiz Hub. Includes past questions and a topic-by-topic 100-question slides set."
  ogUrl="https://lamla-quiz-hub.netlify.app/ethical-computing.html"
  ogImage="https://lamla-quiz-hub.netlify.app/img/ethics-hero.png"
>
  <Navbar links={[
    { label: "Home", href: "/" },
    { label: "Electronics", href: "/electronics" },
    { label: "Literature", href: "/literature" },
    { label: "Visit Lamla AI", href: "https://lamla-ai.vercel.app", external: true },
  ]} />

  <section class="hero">
    <div class="hero-layout">
      <div class="hero-copy">
        <p class="kicker">Ethical Computing | Lamla Quiz Hub</p>
        <h1>Ethical Implications of Computing</h1>
        <p>This page covers the ethical, social, and legal dimensions of computing. Start with either the past-questions set or the 100-question topic-by-topic slides set.</p>
        <div class="hero-actions">
          <a class="btn" href="/">Back to Lamla Quiz Hub</a>
          <a class="btn btn-light" href="#quiz-menu">Open quiz menu</a>
        </div>
      </div>
      <div class="hero-side">
        <div class="hero-badges">
          <span class="hero-badge">Privacy & Security</span>
          <span class="hero-badge">Digital Rights</span>
          <span class="hero-badge">Passco + Slides live</span>
        </div>
        <p style="margin:0; color: rgba(255,255,255,0.9); line-height:1.7;">Both banks are now available: past questions and the full 100-question slide-based set grouped by topic weeks.</p>
      </div>
    </div>
    <div class="feature-strip">
      <div class="feature"><span>Topic 1</span><strong>Privacy, surveillance, and data protection principles.</strong></div>
      <div class="feature"><span>Topic 2</span><strong>Intellectual property, copyright, and open source.</strong></div>
      <div class="feature"><span>Topic 3</span><strong>Professional codes of conduct and computing ethics frameworks.</strong></div>
    </div>
  </section>

  <section id="quiz-menu" class="panel menu">
    <div class="grid">
      <article class="card">
        <div class="tag">Slides Question Bank</div>
        <h2>Topic-by-Topic (100 Questions)</h2>
        <p>Comprehensive slide-based question bank spanning Weeks 1-6, 8, 8b, 9, 10, and 10b with explanations.</p>
        <div class="actions">
          <a class="btn" href="/ethical-computing/ethical_slides_100">Open slides bank</a>
        </div>
      </article>

      <article class="card">
        <div class="tag">Exam Prep</div>
        <h2>Past Questions</h2>
        <p>Ethical Implications of Computing past exam questions covering theories, case studies, and applied ethics scenarios.</p>
        <div class="actions">
          <a class="btn" href="/ethical-computing/ethical_computing">Open past questions</a>
        </div>
      </article>
    </div>

    <div class="note">
      Ethics flow: Lamla Quiz Hub -> Ethical Computing -> choose Past Questions or Topic-by-Topic Slides Bank.
    </div>
  </section>
</Layout>
