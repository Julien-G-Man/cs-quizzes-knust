---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---
<Layout
  title="Operating Systems | Lamla Quiz Hub"
  description="Operating Systems course page inside Lamla Quiz Hub for Linux and OS concept practice."
  ogUrl="https://lamla-quiz-hub.netlify.app/operating-systems"
>
  <Navbar links={[
    { label: "Home", href: "/" },
    { label: "Electronics", href: "/electronics" },
    { label: "Literature", href: "/literature" },
    { label: "Visit Lamla AI", href: "https://lamla-ai.vercel.app", external: true },
  ]} />

  <section class="hero">
    <div class="hero-layout">
      <div class="hero-copy">
        <p class="kicker">Operating Systems | Lamla Quiz Hub</p>
        <h1>Operating Systems Quizzes</h1>
        <p>This is the Operating Systems page for focused practice. Choose from the quizzes that are available now and revise at your own pace.</p>
        <div class="hero-actions">
          <a class="btn" href="/">Back to Lamla Quiz Hub</a>
          <a class="btn btn-light" href="#quiz-menu">Explore quiz sections</a>
        </div>
      </div>
      <div class="hero-side">
        <div class="hero-badges">
          <span class="hero-badge">Linux & Open Source</span>
          <span class="hero-badge">OS concepts</span>
          <span class="hero-badge">Hub access</span>
        </div>
        <p style="margin:0; color: rgba(255,255,255,0.9); line-height:1.7;">Each card opens a live quiz page with the same Lamla-style flow, so you can jump straight into revision.</p>
      </div>
    </div>
    <div class="feature-strip">
      <div class="feature"><span>Available now</span><strong>Linux & Open Source quiz.</strong></div>
      <div class="feature"><span>Content</span><strong>110+ questions covering all major topics.</strong></div>
      <div class="feature"><span>Navigation</span><strong>Use the hub to open the quiz directly.</strong></div>
    </div>
  </section>

  <section id="quiz-menu" class="panel menu">
    <div class="grid">
      <article class="card">
        <div class="tag">Main Set</div>
        <h2>Linux & Open Source</h2>
        <p>Practice with comprehensive questions covering Linux commands, OS concepts, networking, file systems, processes, permissions, and services.</p>
        <div class="actions">
          <a class="btn" href="/operating-systems/linux_and_os">Open Linux quiz</a>
        </div>
      </article>
    </div>

    <div class="note">
      Student flow: Lamla Quiz Hub → Operating Systems Quizzes → select Linux & Open Source practice.
    </div>
  </section>
</Layout>
