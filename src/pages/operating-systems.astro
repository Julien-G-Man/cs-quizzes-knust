---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---
<Layout
  title="Operating Systems | Lamla Quiz Hub"
  description="Operating Systems course page inside Lamla Quiz Hub for Linux and OS concept practice."
  ogUrl="https://lamla-quiz-hub.netlify.app/operating-systems"
>
  <Navbar links={[
    { label: "Home", href: "/" },
    { label: "Electronics", href: "/electronics" },
    { label: "Literature", href: "/literature" },
    { label: "Visit Lamla AI", href: "https://lamla-ai.vercel.app", external: true },
  ]} />

  <section class="hero">
    <div class="hero-layout">
      <div class="hero-copy">
        <p class="kicker">Operating Systems | Lamla Quiz Hub</p>
        <h1>Operating Systems Quizzes</h1>
        <p>This is the Operating Systems page for focused practice. Choose from the quizzes that are available now and revise at your own pace.</p>
        <div class="hero-actions">
          <a class="btn" href="/">Back to Lamla Quiz Hub</a>
          <a class="btn btn-light" href="#quiz-menu">Explore quiz sections</a>
        </div>
      </div>
      <div class="hero-side">
    <div class="hero-badges">
      <span class="hero-badge">Linux Fundamentals</span>
      <span class="hero-badge">Quiz 2</span>
      <span class="hero-badge">Hub access</span>
    </div>
        <p style="margin:0; color: rgba(255,255,255,0.9); line-height:1.7;">Each card opens a live quiz page with the same Lamla-style flow, so you can jump straight into revision.</p>
      </div>
    </div>
    <div class="feature-strip">
      <div class="feature"><span>Available now</span><strong>Three Linux quizzes including mixed question types.</strong></div>
      <div class="feature"><span>Content</span><strong>108 + 64 + 12 questions covering all major Linux topics.</strong></div>
      <div class="feature"><span>Navigation</span><strong>Use the hub to open either quiz directly.</strong></div>
    </div>
  </section>

  <section id="quiz-menu" class="panel menu">
    <div class="grid">
      <article class="card">
        <div class="tag">Main Set</div>
        <h2>Linux Fundamentals</h2>
        <p>108 comprehensive Linux questions covering OS concepts, file systems, disk management, networking, user management, permissions, services, processes, and system administration.</p>
        <div class="actions">
          <a class="btn" href="/operating-systems/linux_fundamentals">Open Linux Fundamentals</a>
        </div>
      </article>

      <article class="card">
        <div class="tag">Quiz 2</div>
        <h2>Linux Quiz 2</h2>
        <p>64 questions compiled from the previous Quiz 2, covering commands, networking, headless servers, daemons, services, file management, and Ubuntu Server concepts.</p>
        <div class="actions">
          <a class="btn" href="/operating-systems/linux_quiz2">Open Quiz 2</a>
        </div>
      </article>

      <article class="card">
        <div class="tag">Quiz 1</div>
        <h2>Linux Quiz 1</h2>
        <p>12 questions on OS processes and threading — mix of multiple choice and fill-in-the-blank. Covers scheduling, zombie processes, IPC, multithreading, and context switching.</p>
        <div class="actions">
          <a class="btn" href="/operating-systems/linux_quiz1">Open Quiz 1</a>
        </div>
      </article>
    </div>

    <div class="note">
      Student flow: Lamla Quiz Hub → Operating Systems Quizzes → select Linux Fundamentals or Quiz 2.
    </div>
  </section>
</Layout>
