---
import Layout from '../../layouts/Layout.astro';
import QuizShell from '../../components/QuizShell.astro';
import questions from '../../data/intro_electronics.json';
---
<Layout
  title="Basic Semiconductor Theory Quiz | Lamla Quiz Hub"
  description="A randomized 100-question quiz on semiconductor theory covering atomic structure, energy bands, PN junctions, and diode behavior."
  ogUrl="https://lamla-quiz-hub.netlify.app/electronics/intro_electronics.html"
>
  <QuizShell
    questions={questions}
    kicker="CSM 251"
    title="Basic Semiconductor Theory"
    description="Choose how many questions you want, then get a random set from the semiconductor theory bank. Covers atoms, energy bands, intrinsic and extrinsic semiconductors, PN junctions, and diode biasing."
    backHref="../electronics.html"
    backLabel="Back to Electronics index"
    defaultCount={20}
    featureMode="Single-page quiz with a question selector."
    featureFlow="Choose count, answer, then submit at any time."
    featureSource="Built from CSM 251 semiconductor theory material."
  />
</Layout>
