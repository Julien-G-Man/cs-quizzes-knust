---
import Layout from '../../layouts/Layout.astro';
import QuizShell from '../../components/QuizShell.astro';
import questions from '../../data/ethical_computing.json';
---
<Layout
  title="Ethics Passco | Lamla Quiz Hub"
  description="Ethics Passco quiz built from a consolidated past-questions bank for ethical, social, and legal computing topics."
  ogUrl="https://lamla-quiz-hub.netlify.app/ethical-computing/passco"
  ogImage="https://lamla-quiz-hub.netlify.app/img/ethics-hero.png"
>
  <QuizShell
    questions={questions}
    kicker="Ethics Passco"
    title="Ethics Passco"
    description="Built from a consolidated past-questions bank (about 120 questions) gathered from multiple class sources. Choose how many questions you want, then get a random set from the Ethics Passco bank covering privacy, data protection, professional responsibility, intellectual property, and applied ethics."
    backHref="/"
    backLabel="Back to Lamla Quiz Hub"
    defaultCount={50}
    featureMode="Single-page quiz with a question selector."
    featureFlow="Choose count, answer, then submit at any time."
    featureSource="Built from a combined past-questions bank sourced from class materials."
  />
</Layout>
