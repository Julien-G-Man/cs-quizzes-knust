---
import Layout from '../../layouts/Layout.astro';
import QuizShell from '../../components/QuizShell.astro';
import questions from '../../data/ethical_computing.json';
---
<Layout
  title="Ethical Implications of Computing Quiz | Lamla Quiz Hub"
  description="A randomized quiz on the ethical, social, and legal dimensions of computing including privacy, professional responsibility, and digital rights."
  ogUrl="https://lamla-quiz-hub.netlify.app/ethical-computing/ethical_computing.html"
>
  <QuizShell
    questions={questions}
    kicker="Ethical Computing"
    title="Ethical Implications of Computing"
    description="Choose how many questions you want, then get a random set from the Ethical Computing question bank. Covers privacy, data protection, professional responsibility, intellectual property, and applied ethics."
    backHref="../ethical-computing.html"
    backLabel="Back to Ethical Computing index"
    defaultCount={20}
    featureMode="Single-page quiz with a question selector."
    featureFlow="Choose count, answer, then submit at any time."
    featureSource="Built from course notes, frameworks, and past exam papers."
  />
</Layout>
