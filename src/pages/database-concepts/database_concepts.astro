---
import Layout from '../../layouts/Layout.astro';
import QuizShell from '../../components/QuizShell.astro';
import questions from '../../data/database_concepts.json';
---
<Layout
  title="Database Concepts & Technologies Quiz | Lamla Quiz Hub"
  description="A randomized quiz on Database Concepts & Technologies covering SQL, relational design, normalisation, and transactions."
  ogUrl="https://lamla-quiz-hub.netlify.app/database-concepts/database_concepts.html"
>
  <QuizShell
    questions={questions}
    kicker="Database Concepts & Technologies"
    title="Database Concepts & Technologies"
    description="Choose how many questions you want, then get a random set from the Database question bank. Covers relational design, SQL, normalisation, transactions, and concurrency."
    backHref="/database-concepts"
    backLabel="Back to Database Concepts index"
    defaultCount={20}
    featureMode="Single-page quiz with a question selector."
    featureFlow="Choose count, answer, then submit at any time."
    featureSource="Built from Database Concepts & Technologies course material and past papers."
  />
</Layout>
