[
  {"q":"An atom consists of:","opts":["Electrons only","Protons only","Electrons, protons, neutrons","Neutrons only"],"ans":2,"cat":"Atomic Structure","difficulty":"easy","explanation":"An atom has a nucleus with protons and neutrons plus electrons around it."},
  {"q":"The outermost shell is called:","opts":["Core shell","Valence shell","Inner shell","Orbital shell"],"ans":1,"cat":"Atomic Structure","difficulty":"easy","explanation":"The valence shell is the outermost shell and controls bonding behavior."},
  {"q":"Electrical conduction requires:","opts":["Protons","Free electrons","Neutrons","Holes only"],"ans":1,"cat":"Basic Concepts","difficulty":"easy","explanation":"Current flows when mobile charge carriers are available."},
  {"q":"At absolute zero, silicon behaves as:","opts":["Conductor","Insulator","Semiconductor","Metal"],"ans":1,"cat":"Basic Concepts","difficulty":"medium","explanation":"Without thermal energy, silicon has essentially no free carriers."},
  {"q":"Silicon has how many valence electrons?","opts":["2","3","4","5"],"ans":2,"cat":"Atomic Structure","difficulty":"easy","explanation":"Silicon is in Group IV, so it has four valence electrons."},
  {"q":"Covalent bonding involves:","opts":["Transfer of electrons","Sharing of electrons","Loss of electrons","Gain of protons"],"ans":1,"cat":"Atomic Structure","difficulty":"easy","explanation":"Covalent bonds form when atoms share electrons to fill outer shells."},
  {"q":"Free electrons exist in:","opts":["Valence band","Conduction band","Nucleus","Core"],"ans":1,"cat":"Energy Bands","difficulty":"easy","explanation":"Electrons in the conduction band are free to move."},
  {"q":"A hole is:","opts":["A proton","Absence of electron","Electron","Neutron"],"ans":1,"cat":"Basic Concepts","difficulty":"easy","explanation":"A hole is the vacancy left when an electron is missing."},
  {"q":"Semiconductor conductivity depends on:","opts":["Pressure","Free electrons","Color","Shape"],"ans":1,"cat":"Basic Concepts","difficulty":"easy","explanation":"More mobile carriers generally mean higher conductivity."},
  {"q":"Silicon crystal structure is formed by:","opts":["Ionic bonding","Covalent bonding","Metallic bonding","Nuclear bonding"],"ans":1,"cat":"Atomic Structure","difficulty":"easy","explanation":"Silicon atoms share electrons in a covalent lattice."},
  {"q":"Energy bands form when:","opts":["Atoms are isolated","Atoms are close together","Temperature is zero","Voltage is applied"],"ans":1,"cat":"Energy Band Theory","difficulty":"medium","explanation":"Nearby atoms cause atomic energy levels to split into bands."},
  {"q":"The valence band contains:","opts":["Free electrons","Bound electrons","Protons","Holes only"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Electrons in the valence band are tied to atoms."},
  {"q":"The conduction band contains:","opts":["Bound electrons","Free electrons","Neutrons","Ions"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Electrons in the conduction band can move through the crystal."},
  {"q":"The band gap is:","opts":["Region with electrons","Forbidden energy region","Conduction band","Valence band"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"No allowed energy states exist in the bandgap."},
  {"q":"Insulators have:","opts":["Small band gap","No band gap","Large band gap","Overlapping bands"],"ans":2,"cat":"Energy Band Theory","difficulty":"easy","explanation":"A large gap makes it hard for electrons to conduct."},
  {"q":"Conductors have:","opts":["Large band gap","Small/no band gap","No electrons","No holes"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Overlapping or nearly touching bands allow conduction."},
  {"q":"Semiconductors have:","opts":["Large band gap","Moderate band gap","Zero band gap","Infinite gap"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Semiconductors sit between conductors and insulators in band gap size."},
  {"q":"Energy gap determines:","opts":["Color","Conductivity","Shape","Weight"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"The size of the gap controls how easily carriers move."},
  {"q":"Electrons require energy to move from:","opts":["Conduction to nucleus","Valence to conduction","Core to valence","Hole to electron"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Electrons must gain energy to cross from valence to conduction band."},
  {"q":"Unit of bandgap energy is:","opts":["Joule","Volt","eV","Ampere"],"ans":2,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Electron volt is the standard unit for semiconductor bandgaps."},
  {"q":"1 eV equals:","opts":["(1.6 × 10<sup>-19</sup>) J","(10<sup>-23</sup>) J","(10<sup>3</sup>) J","1 J"],"ans":0,"cat":"Energy Band Theory","difficulty":"easy","explanation":"One electron volt is the energy gained by one electron across one volt."},
  {"q":"Increasing bandgap:","opts":["Increases conductivity","Decreases conductivity","No effect","Increases current"],"ans":1,"cat":"Energy Band Theory","difficulty":"medium","explanation":"A larger gap makes carrier excitation harder, so conductivity falls."},
  {"q":"Thermal energy causes electrons to:","opts":["Stay bound","Move to conduction band","Disappear","Become holes"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Heating can excite electrons into the conduction band."},
  {"q":"At 0K:","opts":["Electrons in conduction band","All electrons in valence band","No band gap","Infinite current"],"ans":1,"cat":"Energy Band Theory","difficulty":"medium","explanation":"At absolute zero, electrons remain in the valence band in this simplified model."},
  {"q":"Semiconductor bandgap is typically:","opts":["0 eV","~1 eV","10 eV","100 eV"],"ans":1,"cat":"Energy Band Theory","difficulty":"easy","explanation":"Typical semiconductors have bandgaps near 1 eV."},
  {"q":"Intrinsic semiconductor is:","opts":["Doped","Pure","Metallic","Insulating"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Intrinsic means pure or undoped semiconductor material."},
  {"q":"Charge carriers are:","opts":["Only electrons","Only holes","Electrons and holes","Protons"],"ans":2,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Both electrons and holes carry current in semiconductors."},
  {"q":"Electron-hole pair is created by:","opts":["Cooling","Heating","Pressure","Voltage"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Thermal energy can break covalent bonds and create pairs."},
  {"q":"At equilibrium:","opts":["n > p","p > n","n = p","n = 0"],"ans":2,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"In an intrinsic semiconductor, electron and hole concentrations are equal."},
  {"q":"Intrinsic conductivity depends on:","opts":["Temperature","Pressure","Shape","Color"],"ans":0,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Temperature controls how many intrinsic carriers are generated."},
  {"q":"Increasing temperature:","opts":["Decreases carriers","Increases carriers","No change","Removes holes"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Higher temperature generates more electron-hole pairs."},
  {"q":"Recombination is:","opts":["Creation of carriers","Destruction of carriers","Movement of carriers","Voltage flow"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Recombination happens when an electron fills a hole."},
  {"q":"Generation rate equals recombination rate at:","opts":["Breakdown","Equilibrium","Forward bias","Reverse bias"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"medium","explanation":"At equilibrium, creation and annihilation of pairs balance."},
  {"q":"Intrinsic carrier concentration is denoted by:","opts":["n","p","n<sub>i</sub>","N<sub>d</sub>"],"ans":2,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"n<sub>i</sub> is the standard symbol for intrinsic carrier concentration."},
  {"q":"Relationship in intrinsic semiconductor:","opts":["n = p","n > p","p > n","n = 0"],"ans":0,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Intrinsic material has equal electron and hole concentrations."},
  {"q":"Hole movement occurs when:","opts":["Electron leaves","Electron fills vacancy","Proton moves","Ion moves"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"medium","explanation":"A hole appears to move when neighboring electrons shift to fill the vacancy."},
  {"q":"Intrinsic semiconductor has:","opts":["High conductivity","Low conductivity","Zero resistance","Infinite current"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Pure semiconductors conduct less than doped ones."},
  {"q":"Temperature coefficient is:","opts":["Positive","Negative","Zero","Infinite"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"medium","explanation":"Semiconductor resistance typically falls as temperature rises."},
  {"q":"Conductivity increases with:","opts":["Cooling","Heating","Pressure","Voltage"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"easy","explanation":"Heating creates more carriers, raising conductivity."},
  {"q":"Free electrons move:","opts":["Fixed","Randomly","Only forward","Only backward"],"ans":1,"cat":"Intrinsic Semiconductors","difficulty":"medium","explanation":"Carrier motion has a random thermal component even without bias."},
  {"q":"Doping is:","opts":["Cooling","Adding impurities","Heating","Removing electrons"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Doping means introducing controlled impurities into the semiconductor."},
  {"q":"Doping increases:","opts":["Resistance","Conductivity","Bandgap","Mass"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Extra carriers from dopants increase conductivity."},
  {"q":"n-type uses:","opts":["Trivalent","Pentavalent","Monovalent","Divalent"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Pentavalent donors supply extra electrons."},
  {"q":"p-type uses:","opts":["Pentavalent","Trivalent","Divalent","Monovalent"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Trivalent acceptors create holes."},
  {"q":"Donor impurities:","opts":["Accept electrons","Donate electrons","Remove holes","Destroy bonds"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Donor atoms contribute electrons to the crystal."},
  {"q":"Acceptor impurities:","opts":["Donate electrons","Accept electrons","Remove atoms","Increase current"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Acceptor atoms take electrons, leaving holes behind."},
  {"q":"Majority carriers in n-type:","opts":["Holes","Electrons","Protons","Ions"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"n-type material has electrons as the majority carriers."},
  {"q":"Minority carriers in n-type:","opts":["Electrons","Holes","Protons","Neutrons"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Holes are the minority carriers in n-type material."},
  {"q":"Majority carriers in p-type:","opts":["Electrons","Holes","Neutrons","Protons"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"p-type material has holes as the majority carriers."},
  {"q":"Minority carriers in p-type:","opts":["Holes","Electrons","Protons","Ions"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Electrons are the minority carriers in p-type material."},
  {"q":"Doping level is typically:","opts":["(10<sup>22</sup>)","(10<sup>15</sup>)","(10<sup>5</sup>)","1"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"medium","explanation":"Typical doping levels are far below the host atom density, often around 10<sup>15</sup> cm<sup>-3</sup>."},
  {"q":"Silicon atoms per cm³ ≈","opts":["(10<sup>10</sup>)","(10<sup>22</sup>)","(10<sup>5</sup>)","(10<sup>2</sup>)"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"medium","explanation":"Silicon atom density is about 10<sup>22</sup> atoms per cm<sup>3</sup>."},
  {"q":"Relation holds:","opts":["n + p = n<sub>i</sub>","np = n<sub>i</sub><sup>2</sup>","n = p<sup>2</sup>","n = 0"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"At equilibrium, the product n p equals n<sub>i</sub><sup>2</sup>."},
  {"q":"Increasing electrons reduces:","opts":["Electrons","Holes","Temperature","Voltage"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"The carrier product stays fixed at equilibrium, so more electrons means fewer holes."},
  {"q":"Majority carriers depend on:","opts":["Temperature","Doping","Pressure","Voltage"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Doping type determines whether electrons or holes dominate."},
  {"q":"Minority carriers depend on:","opts":["Doping only","Temperature","Pressure","Shape"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"medium","explanation":"Minority carrier concentration is strongly affected by temperature through generation."},
  {"q":"At high temperature extrinsic behaves like:","opts":["Metal","Intrinsic","Insulator","Conductor"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"medium","explanation":"At high temperature, thermally generated carriers dominate dopant carriers."},
  {"q":"Donor level is near:","opts":["Valence band","Conduction band","Band gap center","Nucleus"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"medium","explanation":"Donor levels lie close to the conduction band."},
  {"q":"Acceptor level is near:","opts":["Conduction band","Valence band","Nucleus","Core"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"medium","explanation":"Acceptor levels lie close to the valence band."},
  {"q":"Conductivity of doped > intrinsic:","opts":["False","True","Equal","Zero"],"ans":1,"cat":"Extrinsic Semiconductors","difficulty":"easy","explanation":"Doping adds carriers, so conductivity is higher than in intrinsic material."},
  {"q":"PN junction is formed by:","opts":["Metals","p-type + n-type","Insulators","Conductors"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"A p-n junction is created by joining p-type and n-type semiconductor regions."},
  {"q":"Three processes:","opts":["Heat, light, sound","Diffusion, drift, space charge","Voltage, current, resistance","Energy, power, force"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"PN junction behavior is described by diffusion, drift, and the space charge region."},
  {"q":"Diffusion occurs due to:","opts":["Electric field","Concentration gradient","Voltage","Heat only"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"Carriers move from high concentration to low concentration."},
  {"q":"Drift occurs due to:","opts":["Concentration gradient","Electric field","Pressure","Voltage only"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"The internal electric field drives drift motion."},
  {"q":"Depletion region has:","opts":["Free carriers","No carriers","Electrons only","Holes only"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"The depletion region is depleted of mobile carriers."},
  {"q":"Depletion region contains:","opts":["Neutral atoms","Ions","Free electrons","Holes"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"After diffusion, fixed ionized donors and acceptors remain."},
  {"q":"Barrier potential is formed due to:","opts":["Drift","Diffusion","Recombination","Voltage"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"Carrier diffusion creates the charge separation that leads to the barrier."},
  {"q":"Typical barrier potential:","opts":["0V","0.1–0.3V","5V","10V"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"A basic PN junction barrier is often around a few tenths of a volt in simplified treatment."},
  {"q":"Electric field direction:","opts":["n → p","p → n","random","none"],"ans":0,"cat":"PN Junction","difficulty":"medium","explanation":"The fixed positive ions are on the n-side and the fixed negative ions are on the p-side, so the field points from n to p."},
  {"q":"Diffusion current direction:","opts":["n → p","p → n","none","random"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"Conventional diffusion current is from p to n because both hole diffusion and electron diffusion produce current in that direction."},
  {"q":"At equilibrium:","opts":["I<sub>D</sub> > I<sub>S</sub>","I<sub>D</sub> < I<sub>S</sub>","I<sub>D</sub> = I<sub>S</sub>","I<sub>D</sub> = 0"],"ans":2,"cat":"PN Junction","difficulty":"medium","explanation":"The diffusion and drift currents exactly balance at equilibrium."},
  {"q":"Depletion width increases when:","opts":["diffusion increases","drift increases","temperature drops","voltage zero"],"ans":0,"cat":"PN Junction","difficulty":"hard","explanation":"More diffusion tends to expand the depletion region as charge separation grows."},
  {"q":"No external current in:","opts":["forward bias","reverse bias","open circuit","closed circuit"],"ans":2,"cat":"PN Junction","difficulty":"easy","explanation":"An open circuit allows no continuous current flow."},
  {"q":"Junction is neutral outside:","opts":["False","True","Partially","Unknown"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"Outside the depletion region, the semiconductor remains neutral overall."},
  {"q":"Space charge region is:","opts":["depletion region","conductor","insulator","metal"],"ans":0,"cat":"PN Junction","difficulty":"easy","explanation":"The space charge region is the same as the depletion region."},
  {"q":"Barrier prevents:","opts":["drift","diffusion","current","voltage"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"The barrier opposes further diffusion of majority carriers."},
  {"q":"Built-in potential is:","opts":["external","internal","zero","infinite"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"It is the internal potential across the depletion region."},
  {"q":"Depletion region forms due to:","opts":["doping","diffusion","drift","heating"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"Diffusion of carriers after contact creates the depleted region."},
  {"q":"Electric field opposes:","opts":["drift","diffusion","recombination","voltage"],"ans":1,"cat":"PN Junction","difficulty":"medium","explanation":"The built-in field opposes diffusion and restores equilibrium."},
  {"q":"Junction thickness is:","opts":["large","very small","zero","infinite"],"ans":1,"cat":"PN Junction","difficulty":"easy","explanation":"A PN junction exists over a very thin transition region."},
  {"q":"Forward bias:","opts":["p→negative","p→positive","no connection","reverse"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Forward bias connects the p-side to the positive terminal and the n-side to the negative terminal."},
  {"q":"Reverse bias:","opts":["p→positive","p→negative","equal","none"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Reverse bias connects the p-side to the negative terminal and the n-side to the positive terminal."},
  {"q":"Forward bias reduces:","opts":["current","barrier","voltage","charge"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Forward bias lowers the barrier potential."},
  {"q":"Reverse bias increases:","opts":["current","barrier","conductivity","carriers"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Reverse bias increases the barrier and depletion region."},
  {"q":"Forward bias causes:","opts":["small current","large current","zero current","no effect"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Forward bias allows significant current to flow."},
  {"q":"Reverse bias current is:","opts":["large","small","infinite","zero always"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Reverse current is typically tiny compared to forward current."},
  {"q":"Depletion region in forward bias:","opts":["widens","narrows","constant","disappears"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Forward bias reduces the depletion width."},
  {"q":"Depletion region in reverse bias:","opts":["narrows","widens","constant","disappears"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Reverse bias pulls carriers away and widens the depletion region."},
  {"q":"Threshold voltage exists in:","opts":["reverse","forward","both","none"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Forward conduction starts around a threshold level."},
  {"q":"Diode is:","opts":["linear","nonlinear","resistor","capacitor"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"A diode does not obey a linear current-voltage law."},
  {"q":"I-V curve is:","opts":["linear","exponential","constant","zero"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Diode current grows exponentially with voltage."},
  {"q":"Reverse current depends on:","opts":["voltage only","temperature","resistance","pressure"],"ans":1,"cat":"Biasing & I-V","difficulty":"medium","explanation":"Reverse leakage current increases strongly with temperature."},
  {"q":"Breakdown occurs in:","opts":["forward","reverse","open","none"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Breakdown is a reverse-bias phenomenon."},
  {"q":"Breakdown voltage:","opts":["Vt","Vz","Vs","Vi"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"V<sub>z</sub> is the common symbol for breakdown voltage in this context."},
  {"q":"Zener breakdown occurs at:","opts":["<5V",">7V","10V","0V"],"ans":0,"cat":"Biasing & I-V","difficulty":"medium","explanation":"Zener breakdown is associated with lower reverse voltages."},
  {"q":"Avalanche breakdown occurs at:","opts":["<2V",">7V","1V","0V"],"ans":1,"cat":"Biasing & I-V","difficulty":"medium","explanation":"Avalanche breakdown typically appears at higher reverse voltages."},
  {"q":"Avalanche occurs due to:","opts":["heat","collisions","voltage","holes"],"ans":1,"cat":"Biasing & I-V","difficulty":"medium","explanation":"Impact ionization from collisions causes avalanche breakdown."},
  {"q":"Zener occurs due to:","opts":["collisions","strong electric field","heat","doping"],"ans":1,"cat":"Biasing & I-V","difficulty":"medium","explanation":"A very strong field can pull carriers through the barrier."},
  {"q":"Breakdown current:","opts":["decreases","increases sharply","constant","zero"],"ans":1,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Once breakdown begins, current rises very quickly."},
  {"q":"Breakdown is safe if:","opts":["current limited","voltage zero","temp zero","no doping"],"ans":0,"cat":"Biasing & I-V","difficulty":"easy","explanation":"Current limiting prevents damage during breakdown operation."}
